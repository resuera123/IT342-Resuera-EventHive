<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <ImageButton
                android:id="@+id/btnBackFromCreate"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Event"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Image Picker -->
        <LinearLayout
            android:id="@+id/layoutImagePicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_image_picker"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/ivEventImagePreview"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvImageHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to add event image"
                android:textColor="#6B7280"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Title -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Event Title" android:textSize="13sp" android:textStyle="bold" android:textColor="#374151"/>
        <EditText
            android:id="@+id/etEventTitle"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="Enter event title"
            android:textSize="13sp"
            android:paddingStart="12dp"
            android:background="@drawable/bg_edit_text"
            android:layout_marginBottom="12dp"/>

        <!-- Description -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Description" android:textSize="13sp" android:textStyle="bold" android:textColor="#374151"/>
        <EditText
            android:id="@+id/etEventDesc"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:hint="Describe your event"
            android:textSize="13sp"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:gravity="top"
            android:background="@drawable/bg_edit_text"
            android:layout_marginBottom="12dp"/>

        <!-- Dates -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Start Date &amp; Time" android:textSize="12sp" android:textStyle="bold" android:textColor="#374151"/>
                <Button android:id="@+id/btnStartDate" android:layout_width="match_parent" android:layout_height="40dp"
                    android:text="Select..." android:textAllCaps="false" android:textSize="12sp"
                    android:backgroundTint="#F3F4F6" android:textColor="#374151"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="End Date &amp; Time" android:textSize="12sp" android:textStyle="bold" android:textColor="#374151"/>
                <Button android:id="@+id/btnEndDate" android:layout_width="match_parent" android:layout_height="40dp"
                    android:text="Select..." android:textAllCaps="false" android:textSize="12sp"
                    android:backgroundTint="#F3F4F6" android:textColor="#374151"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Location -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Location" android:textSize="13sp" android:textStyle="bold" android:textColor="#374151"/>
        <EditText
            android:id="@+id/etEventLocation"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="Enter event location"
            android:textSize="13sp"
            android:paddingStart="12dp"
            android:background="@drawable/bg_edit_text"
            android:layout_marginBottom="12dp"/>

        <!-- Category + Max -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Category" android:textSize="12sp" android:textStyle="bold" android:textColor="#374151"/>
                <Spinner android:id="@+id/spinnerCategory" android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="@drawable/bg_spinner_outline"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Max Participants" android:textSize="12sp" android:textStyle="bold" android:textColor="#374151"/>
                <EditText android:id="@+id/etMaxParticipants" android:layout_width="match_parent" android:layout_height="44dp"
                    android:hint="e.g. 100" android:textSize="13sp" android:inputType="number" android:paddingStart="12dp"
                    android:background="@drawable/bg_edit_text"/>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnCreateEvent"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Create Event"
            android:textAllCaps="false"
            android:backgroundTint="#198754"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnCancelCreate"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:backgroundTint="#F3F4F6"
            android:textColor="#374151"/>
    </LinearLayout>
</ScrollView>