<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:background="#FFFFFF"
        android:elevation="2dp">
        <ImageButton
            android:id="@+id/btnBackFromSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- 3 Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">
        <Button android:id="@+id/btnTabProfile" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="Profile" android:textSize="11sp" android:textAllCaps="false"
            android:backgroundTint="#212529" android:textColor="#FFFFFF" android:insetTop="0dp" android:insetBottom="0dp"/>
        <Button android:id="@+id/btnTabNotifications" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="Notifications" android:textSize="11sp" android:textAllCaps="false"
            android:backgroundTint="#FFFFFF" android:textColor="#212529" android:insetTop="0dp" android:insetBottom="0dp"/>
        <Button android:id="@+id/btnTabSecurity" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="Security" android:textSize="11sp" android:textAllCaps="false"
            android:backgroundTint="#FFFFFF" android:textColor="#212529" android:insetTop="0dp" android:insetBottom="0dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ═══ Profile Tab ═══ -->
            <LinearLayout
                android:id="@+id/layoutProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Profile Information" android:textSize="16sp" android:textStyle="bold" android:textColor="#111827"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Update your personal information" android:textSize="12sp" android:textColor="#6B7280" android:layout_marginBottom="16dp"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="First Name" android:textSize="12sp" android:textStyle="bold" android:textColor="#374151"/>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense" app:hintEnabled="false" android:layout_marginBottom="10dp">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSettingsFirstName" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Last Name" android:textSize="12sp" android:textStyle="bold" android:textColor="#374151"/>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense" app:hintEnabled="false" android:layout_marginBottom="10dp">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSettingsLastName" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email Address" android:textSize="12sp" android:textStyle="bold" android:textColor="#374151"/>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense" app:hintEnabled="false" android:layout_marginBottom="16dp">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSettingsEmail" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:inputType="textEmailAddress"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView android:id="@+id/tvProfileMsg" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:visibility="gone" android:layout_marginBottom="8dp"/>
                        <Button android:id="@+id/btnSaveProfile" android:layout_width="match_parent" android:layout_height="42dp" android:text="Save Changes" android:textAllCaps="false" android:backgroundTint="#212529"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ═══ Notifications Tab ═══ -->
            <LinearLayout
                android:id="@+id/layoutNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="In-App Notifications" android:textSize="16sp" android:textStyle="bold" android:textColor="#111827"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Choose which notifications appear" android:textSize="12sp" android:textColor="#6B7280" android:layout_marginBottom="20dp"/>

                        <!-- Registration -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Registration Confirmations" android:textSize="13sp" android:textStyle="bold" android:textColor="#374151"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="When you register for an event" android:textSize="11sp" android:textColor="#6B7280"/>
                            </LinearLayout>
                            <Switch android:id="@+id/swRegistration" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginBottom="16dp"/>

                        <!-- Event Updates -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Event Updates" android:textSize="13sp" android:textStyle="bold" android:textColor="#374151"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="When a joined event is resumed" android:textSize="11sp" android:textColor="#6B7280"/>
                            </LinearLayout>
                            <Switch android:id="@+id/swEventUpdates" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginBottom="16dp"/>

                        <!-- Cancellation -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cancellation Alerts" android:textSize="13sp" android:textStyle="bold" android:textColor="#374151"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="When a joined event is cancelled" android:textSize="11sp" android:textColor="#6B7280"/>
                            </LinearLayout>
                            <Switch android:id="@+id/swCancellation" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginBottom="16dp"/>

                        <!-- New Participant -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="New Participants" android:textSize="13sp" android:textStyle="bold" android:textColor="#374151"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="When someone joins your event (organizers)" android:textSize="11sp" android:textColor="#6B7280"/>
                            </LinearLayout>
                            <Switch android:id="@+id/swNewParticipant" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <Button android:id="@+id/btnSaveNotifs" android:layout_width="match_parent" android:layout_height="42dp" android:text="Save Preferences" android:textAllCaps="false" android:backgroundTint="#212529"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ═══ Security Tab ═══ -->
            <LinearLayout
                android:id="@+id/layoutSecurity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <!-- Change Password -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Change Password" android:textSize="16sp" android:textStyle="bold" android:textColor="#111827"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Keep your account secure" android:textSize="12sp" android:textColor="#6B7280" android:layout_marginBottom="16dp"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Current Password" android:textSize="12sp" android:textStyle="bold" android:textColor="#374151"/>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense" app:hintEnabled="false" app:passwordToggleEnabled="true" android:layout_marginBottom="10dp">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etCurrentPassword" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:inputType="textPassword"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="New Password" android:textSize="12sp" android:textStyle="bold" android:textColor="#374151"/>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense" app:hintEnabled="false" app:passwordToggleEnabled="true" android:layout_marginBottom="10dp">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etNewPassword" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:inputType="textPassword"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Confirm New Password" android:textSize="12sp" android:textStyle="bold" android:textColor="#374151"/>
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense" app:hintEnabled="false" app:passwordToggleEnabled="true" android:layout_marginBottom="16dp">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etConfirmNewPassword" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:inputType="textPassword"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView android:id="@+id/tvSecurityMsg" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:visibility="gone" android:layout_marginBottom="8dp"/>
                        <Button android:id="@+id/btnChangePassword" android:layout_width="match_parent" android:layout_height="42dp" android:text="Update Password" android:textAllCaps="false" android:backgroundTint="#212529"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Danger Zone -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:strokeColor="#DC3545"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Danger Zone" android:textSize="16sp" android:textStyle="bold" android:textColor="#DC3545"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Irreversible actions on your account" android:textSize="12sp" android:textColor="#6B7280" android:layout_marginBottom="16dp"/>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Delete Account" android:textSize="13sp" android:textStyle="bold" android:textColor="#374151"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Permanently delete your account" android:textSize="11sp" android:textColor="#6B7280"/>
                            </LinearLayout>
                            <Button android:id="@+id/btnDeleteAccount" android:layout_width="wrap_content" android:layout_height="36dp"
                                android:text="Delete" android:textAllCaps="false" android:textSize="12sp"
                                android:backgroundTint="#DC3545" android:textColor="#FFFFFF"
                                android:insetTop="0dp" android:insetBottom="0dp"
                                android:paddingStart="16dp" android:paddingEnd="16dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </FrameLayout>
    </ScrollView>
</LinearLayout>